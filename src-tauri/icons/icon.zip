	<script src="https://www.iconpacks.net/js/popovers.js"></script>

	<script>

$(document).ready(function(){
	// local storage
	
	const keyLocalStorage = "cachedIds_ipacks";
	
	function clearLocalStorage() {
    // Check if localStorage is supported by the browser
    if (typeof Storage !== "undefined") {
        localStorage.clear();
        console.log("All data cleared from localStorage.");
    } else {
        console.error("localStorage is not supported in this browser.");
    }
}
	
	//clearLocalStorage();
	
	function addToLocalStorage(key, value) {
    if (typeof Storage !== "undefined") {
        let existingData = JSON.parse(localStorage.getItem(key)) || [];
        const id = value[0];
        const idExists = existingData.some(row => row[0] === id);

        if (idExists) {
            console.log('ID '+id+' already exists in localStorage');
            return; // Exit the function if ID exists
        }
        existingData.push(value);
        localStorage.setItem(key, JSON.stringify(existingData));

        console.log('Item '+JSON.stringify(value)+' added to localStorage');
    } else {
        console.error("localStorage is not supported in this browser.");
    }
}
	
	
	function viewLocalStorageData() {
		if (typeof Storage !== "undefined") {
			for (let i = 0; i < localStorage.length; i++) {
			
				const value = JSON.parse(localStorage.getItem(keyLocalStorage));
			}
		} else {
			console.error("localStorage is not supported in this browser.");
		}
	}
	
	
	function countStorageData() {
		if (typeof Storage !== "undefined") {
			var storedIds = JSON.parse(localStorage.getItem(keyLocalStorage)) || [];
			var countLocalStorage=storedIds.length;		
			$("#local-counter").html(countLocalStorage);
		} else {
			console.error("localStorage is not supported in this browser.");
		}
	}
	
	countStorageData();
	
	
	function getStored() {

		var storedIds = JSON.parse(localStorage.getItem(keyLocalStorage)) || [];

		var slides = document.getElementsByClassName("icon-save");
		var get_attr_id;
		for (var i = 0; i < slides.length; i++) {
		   get_attr_id=slides[i].getAttribute("data-id");
			
		   let existingData = JSON.parse(localStorage.getItem(keyLocalStorage)) || [];
		   const foundRow = existingData.find(row => row[0] === get_attr_id);
			if (foundRow) {	
				$("#icon-save-"+get_attr_id).find('path').css("fill", "#b5b5b6");
			}
		
		}
	}
	
	
	
	function removeFromLocalStorageByID(key, id) {
 
		if (typeof Storage !== "undefined") {
			let existingData = JSON.parse(localStorage.getItem(key)) || [];
			const newData = existingData.filter(row => row[0] !== id);
			localStorage.setItem(key, JSON.stringify(newData));
		} else {
			console.error("localStorage is not supported in this browser.");
		}
	}
	
	getStored();
	
	
	
	
	
	$(".icon-save").hide();
	
	$(".icon").hover(function(){
		$(".icon-save").hide();
		$(this).find(".icon-save").show(); 
	}, function(){});
	
	
	
	$(".icon-save, .icon-save-2").click(function(){
		var id = $(this).attr("data-id");
		var path=$(this).attr("data-path");
		var perma=$(this).attr("data-perma");
		var imgname=$(this).attr("data-imgname");
		
		console.log(id+","+path+","+perma);

		if($(this).find('path').css("fill")=="none")
		{
			$(this).find('path').css("fill", "#b5b5b6");
			const newValue1 = [id, path, perma,imgname];
			addToLocalStorage(keyLocalStorage, newValue1);
			//viewLocalStorageData();
			

		}
		else
		{
			$(this).find('path').css("fill", "none");
			removeFromLocalStorageByID(keyLocalStorage,id);
			viewLocalStorageData();
		}
		countStorageData();
	
});
	
  
}); // d ready


</script>
