{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeTaoSSH",
  "version": "0.1.2",
  "identifier": "com.HeTaoSSH.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HeTaoSSH",
        "decorations": false,
        "transparent": true,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hthappy/HeTaoSSH/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyQ0M4REM2MjY0OUZBQzQKUldURStra214bzNNd3JrK2FZUHU2UllUN2R3aWRKQUxzeVJVYXdMb1Rram5Dd3hzTmFjbkQyVWcK"
    },
    "shell": {},
    "fs": {}
  }
}
