{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeTaoSSH",
  "version": "0.1.0",
  "identifier": "com.HeTaoSSH.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HeTaoSSH",
        "decorations": false,
        "transparent": true,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "category": "DeveloperTool"
  },
  "plugins": {
    "shell": {},
    "fs": {}
  }
}